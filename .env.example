# Application
APP_ENV=dev
APP_NAME=Local SEO Optimizer
APP_VERSION=0.1.0
DEBUG=true
SCHEDULER_ENABLED=false
SCHEDULER_TARGET=jobs

# Database
DATABASE_URL=postgresql+psycopg2://seo:seopassword@localhost:5432/seo_optimizer

# JWT Authentication
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_COOKIE_PATH=/
OAUTH_STATE_TTL_SECONDS=900

# Google Cloud Storage
GCS_BUCKET=
S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json  # Local development only
# Stripe (for billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Plan Price IDs - public managed pilot checkout
STRIPE_PRICE_MAPS_STARTER_MONTHLY=price_maps_starter_monthly
STRIPE_PRICE_MAPS_STARTER_YEARLY=price_maps_starter_yearly
STRIPE_PRICE_CALLS_GROWTH_MONTHLY=price_calls_growth_monthly
STRIPE_PRICE_CALLS_GROWTH_YEARLY=price_calls_growth_yearly
STRIPE_PRICE_COMPETITIVE_MARKET_MONTHLY=price_competitive_market_monthly
STRIPE_PRICE_COMPETITIVE_MARKET_YEARLY=price_competitive_market_yearly

# Stripe Plan Price IDs - legacy self-serve plans kept for existing subscriptions
STRIPE_PRICE_STARTER_MONTHLY=price_starter_monthly
STRIPE_PRICE_STARTER_YEARLY=price_starter_yearly
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly
STRIPE_PRICE_PRO_YEARLY=price_pro_yearly
STRIPE_PRICE_PREMIUM_MONTHLY=price_premium_monthly
STRIPE_PRICE_PREMIUM_YEARLY=price_premium_yearly
STRIPE_PRICE_AGENCY_MONTHLY=price_agency_monthly
STRIPE_PRICE_AGENCY_YEARLY=price_agency_yearly

# Stripe Credit Package Price IDs (one-time payments, optional)
# Create these as one-time prices in the Stripe dashboard first.
# If left empty, inline price_data is used; no dashboard setup required.
STRIPE_PRICE_CREDITS_50=    # 50 credits  $4.99
STRIPE_PRICE_CREDITS_100=   # 100 credits $8.99
STRIPE_PRICE_CREDITS_250=   # 250 credits $19.99
STRIPE_PRICE_CREDITS_500=   # 500 credits $34.99

# Stripe Add-on Price IDs
STRIPE_PRICE_ADDON_MCB=price_addon_mcb       # Missed Call Text Back $29/mo
STRIPE_PRICE_ADDON_RB=price_addon_rb         # Review Booster $39/mo
STRIPE_PRICE_ADDON_SEO=price_addon_seo       # Website SEO $49/mo
STRIPE_PRICE_ADDON_SAR=price_addon_sar       # Social Auto-Responder $29/mo
STRIPE_PRICE_ADDON_VIDEO=price_addon_video   # Video Generator $49/mo

# Google Business Profile
GBP_API_KEY=
GBP_CLIENT_ID=
GBP_CLIENT_SECRET=

# Instagram / Facebook
IG_APP_ID=
IG_APP_SECRET=

# LLM Provider
LLM_PROVIDER=gemini
LLM_MODEL=gemini-1.5-pro
GEMINI_API_KEY=
OPENAI_API_KEY=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@localseo.app

# Application URL (for OAuth callbacks, email links)
APP_URL=http://localhost:3000

# Production notes
# - Set APP_ENV=prod
# - Set DEBUG=false
# - Before release, run: python scripts/check_prod_env.py --require-prod
# - Run schedulers only in a dedicated worker process by setting SCHEDULER_ENABLED=true there
# - Start the worker with: python -m app.worker
# - Use the public frontend URL for APP_URL (Cloud Run deploy scripts now backfill this after frontend deploy)
# - Keep AUTH_COOKIE_PATH=/ unless you intentionally need a narrower public API prefix
# - Use PostgreSQL for DATABASE_URL
# - Configure live Stripe secret/webhook values plus all managed pilot STRIPE_PRICE_* plan IDs
# - Configure cloud storage, SendGrid, the selected LLM provider key, GBP OAuth, and Instagram OAuth
# - On Cloud Run, GCS_BUCKET can rely on the service account's ambient auth; local dev still needs GOOGLE_APPLICATION_CREDENTIALS
# - If Twilio is enabled, set TWILIO_PHONE_NUMBER
# - If SendGrid is enabled, set SENDGRID_FROM_EMAIL (or match EMAIL_FROM)

# Notification Channels
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
KAKAO_API_TOKEN=
SENTRY_DSN=

# Twilio (Missed Call Text Back)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# SendGrid (Email)
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=billing@localseo.app

